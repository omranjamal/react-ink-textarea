{
  "name": "ink-textarea",
  "version": "0.1.0",
  "description": "A multiline textarea component for Ink",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ink",
    "react",
    "cli",
    "textarea",
    "input",
    "terminal"
  ],
  "author": "Omran Jamal",
  "license": "MIT",
  "peerDependencies": {
    "ink": "^6.0.0 || ^7.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "files": [
    "dist/"
  ]
}
